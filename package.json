{
  "name": "spec-sniffer",
  "version": "1.0.0",
  "description": "Reverse-engineers API documentation by crawling a web app with a headless browser",
  "main": "dist/index.js",
  "bin": {
    "spec-sniffer": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "postinstall": "npx playwright install chromium",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["api", "openapi", "swagger", "reverse-engineer", "playwright", "crawler"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "openai": "^4.70.0",
    "playwright": "^1.48.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=18"
  }
}
